use Div, P, Span

const paragraphElement = element P('A paragraph of text.');

//*
const DivElement = element Div(
    element Div('hello')
);
//*

//:

const SpanElement = element Span(() => 'Hello');


const a = [
    element Span(
        element P('Hello World!')
    ),
    element Div(
        element Span(
            'Hello.'
        )
    )
]


append element a;